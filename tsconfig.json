{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "lib": ["DOM", "ESNext"],
        "types": ["bun-types", "node", "svelte"]
    },
    "include": [
        "*.ts",
        "*.d.ts",
        "ui/**/*.ts",
        "ui/**/*.d.ts",
        "ui/**/*.svelte",
        "use/**/*.ts",
        "route/**/*.ts",
        "route/**/*.d.ts",
        "route/**/*.svelte",
        "builder/**/*.ts",
        "tests/**/*.ts"
    ]
}
