{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "lib": ["DOM", "ESNext"],
        "types": ["bun", "node", "svelte"]
    },
    "include": [
        "*.ts",
        "*.d.ts",
        "src/**/*.ts",
        "src/**/*.d.ts",
        "src/**/*.svelte",
        "tests/**/*.ts"
    ]
}
