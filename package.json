{
    "name": "svelte-lib",
    "version": "1.0.0",
    "module": "./src/_.ts",
    "exports": {
        ".": "./src/_.ts",
        "./ui": "./src/ui/_.ts",
        "./use": "./src/use/_.ts",
        "./route": "./src/route/_.ts",
        "./builder": "./src/builder/_.ts",
        "./package.json": "./package.json"
    },
    "bin": {
        "svelte-build": "./src/builder/build.ts",
        "svelte-dev": "./src/builder/dev.ts"
    },
    "files": ["src", "README.md", "global.d.ts"],
    "type": "module",
    "scripts": {
        "test": "bun test --conditions=browser",
        "typecheck": "svelte-check --tsconfig ./tsconfig.json"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/node": "latest",
        "jsdom": "latest",
        "svelte": "latest",
        "svelte-check": "latest",
        "typescript": "latest"
    },
    "peerDependencies": {
        "svelte": "latest"
    }
}
