{
    "name": "@svelte-lib/builder",
    "version": "1.0.0",
    "type": "module",
    "exports": {
        ".": "./build.ts",
        "./package.json": "./package.json"
    },
    "bin": {
        "svelte-builder": "./build.ts"
    },
    "scripts": {
        "dev": "bun run build.ts dev",
        "build": "bun run build.ts build"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/node": "latest",
        "esbuild": "latest",
        "svelte": "latest"
    },
